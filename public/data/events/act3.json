    {
      "id": "act3_john_family_pickup",
      "category": "FIXED",
      "name": "约翰的「顺路」服务",
      "description": "你跟卡车司机约翰聊起家事，提到还有家人困在墨西哥那边。约翰咧嘴一笑：「我也有家人在那边，跑这条线多年了。只要你出路费，我下趟去墨西哥可以帮你把人接过来。」",
      "scenes": ["act3"],
      "execution": {
        "repeatable": false,
        "actionPointCost": 1
      },
      "choices": [
        {
          "id": "pay_pickup",
          "name": "给$800油费，让他接人",
          "condition": {
            "type": "ATTRIBUTE",
            "attribute": "social",
            "operator": ">=",
            "value": 12
          },
          "effects": {
            "resources": {
              "money": -800,
              "moneyCurrency": "USD",
              "mental": 5
            },
            "setFlags": {
              "john_family_pickup": true,
              "family_reunited": false
            },
            "narrative": "约翰拍了拍你的肩膀：「放心，包在我身上。一周后的这个点，你在家等着。」你把钱交给他，心里既期待又忐忑。"
          }
        },
        {
          "id": "haggle",
          "name": "砍价到$500",
          "condition": {
            "type": "ATTRIBUTE",
            "attribute": "social",
            "operator": ">=",
            "value": 15
          },
          "effects": {
            "resources": {
              "money": -500,
              "moneyCurrency": "USD",
              "mental": 3
            },
            "setFlags": {
              "john_family_pickup_cheap": true,
              "family_reunited": false
            },
            "narrative": "约翰挠挠头：「行吧，看在咱们聊得来的份上，500就500。但要是路上出啥岔子，你可别赖我。」"
          }
        },
        {
          "id": "decline",
          "name": "算了，太危险",
          "effects": {
            "narrative": "你摇摇头。约翰耸耸肩：「随你。这活确实有风险，边境那边现在查得紧。」"
          }
        }
      ],
      "tags": ["driver", "transport", "social", "family"]
